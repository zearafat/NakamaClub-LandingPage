---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="relative h-dvh bg-white overflow-hidden flex flex-col">
		<!-- Blue Section -->
		<div class="relative flex-1 bg-[#0A8BFF] flex flex-col">
			<!-- Header -->
			<header class="relative z-20 flex items-center justify-between px-6 py-5 md:px-12 lg:px-16 md:py-6">
				<a href="/">
					<img src="/logo.svg" alt="Nakama" class="h-8 md:h-10 lg:h-12" />
				</a>
				<a
					href="https://x.com"
					target="_blank"
					rel="noopener noreferrer"
					class="bg-[#1A1A2E] text-white text-sm md:text-base font-semibold px-5 py-2.5 md:px-6 md:py-3 rounded-full hover:bg-[#2A2A3E] transition-colors"
				>
					Follow our X
				</a>
			</header>

			<!-- Hero Content -->
			<main class="relative z-10 flex-1 flex flex-col items-center text-center pt-4 md:pt-8 lg:pt-14">
				<h1 class="text-white text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight">
					Coming soon...
				</h1>
				<p class="text-white/90 text-base md:text-lg lg:text-xl mt-3 md:mt-5">
					Something magical is still in the oven 🧑‍🍳
				</p>

				<!-- Hero Illustration -->
				<div class="relative mt-6 md:mt-10 lg:mt-12 w-full max-w-[280px] md:max-w-[460px] lg:max-w-[580px] mx-auto px-4">
					<img
						src="/hero-illustration.png"
						alt="Nakama characters"
						class="w-full h-auto relative z-10"
					/>
				</div>
			</main>

			<!-- Clouds Back (behind) — slightly higher than front -->
			<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[140%] md:w-[130%] lg:w-[120%] z-[1] pointer-events-none translate-y-[35%]">
				<img src="/clouds-back.svg" alt="" class="w-full h-auto block translate-y-[-5%]" />
			</div>

			<!-- Clouds Front -->
			<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[140%] md:w-[130%] lg:w-[120%] z-[5] pointer-events-none translate-y-[38%]">
				<img src="/clouds-front.svg" alt="" class="w-full h-auto block" />
			</div>
		</div>

		<!-- Footer -->
		<footer class="relative z-20 bg-white shrink-0 px-6 py-4 md:px-12 lg:px-16 md:py-5 flex flex-col md:flex-row items-center justify-between gap-1">
			<p class="text-sm md:text-base text-gray-800 font-semibold">
				Made with 🧡 in Yogyakarta
			</p>
			<p class="text-sm md:text-base text-gray-500">
				Nakama ~ Design Engineer Club
			</p>
		</footer>
	</div>
</Layout>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

	:global(html, body) {
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		margin: 0;
		padding: 0;
	}
</style>
